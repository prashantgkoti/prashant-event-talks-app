# pyenv
#   For a library or app, you might want to share your .python-version if the
#   project is co-developed in multiple versions of Python.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different platforms, you may let them generate their own lock file.
# lock files should generally be checked in if you are building an application.

# poetry
#   Poetry uses pyproject.toml and poetry.lock. lock files should be checked in.

# pdm
#   PDM uses pyproject.toml and pdm.lock. lock files should be checked in.

# pip-tools
#   Requirements files generated by pip-compile.

